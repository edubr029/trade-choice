{
  "schemaVersion": 1,
  "id": "tradechoice",
  "version": "${version}",
  "name": "Trade Choice",
  "description": "Multi-loader Fabric + NeoForge mod for marking and alerting on desired villager trades.",
  "authors": ["edu"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["com.tradechoice.client.TradeChoiceFabricClient"]
  },
  "mixins": [
    {
      "config": "tradechoice.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "trade_cycling": "*"
  }
}
